{
  "$schema":"https://openapi.vercel.sh/vercel.json",
  "cleanUrls":true,
  "trailingSlash":false,
  "redirects":[
    {"source":"/","destination":"/index.html","permanent":false},
    {"source":"/students","destination":"/section.html?view=students","permanent":false},
    {"source":"/admissions","destination":"/section.html?view=admissions","permanent":false},
    {"source":"/staff","destination":"/section.html?view=staff","permanent":false},
    {"source":"/access","destination":"/section.html?view=access","permanent":false},
    {"source":"/sync","destination":"/section.html?view=sync","permanent":false}
  ],
  "headers":[
    {"source":"/(.*)","headers":[
      {"key":"X-Content-Type-Options","value":"nosniff"},
      {"key":"Referrer-Policy","value":"strict-origin-when-cross-origin"},
      {"key":"Permissions-Policy","value":"camera=(), geolocation=(), microphone=()"},
      {"key":"X-Frame-Options","value":"DENY"},
      {"key":"Cache-Control","value":"no-store, max-age=0"}
    ]}
  ]
}
