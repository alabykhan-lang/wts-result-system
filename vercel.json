{
  "$schema":"https://openapi.vercel.sh/vercel.json",
  "cleanUrls":true,
  "trailingSlash":false,
  "redirects":[
    {"source":"/","destination":"/central-registry/index.html","permanent":false},
    {"source":"/registry","destination":"/central-registry/index.html","permanent":false},
    {"source":"/students","destination":"/central-registry/section.html?view=students","permanent":false},
    {"source":"/admissions","destination":"/central-registry/section.html?view=admissions","permanent":false},
    {"source":"/staff","destination":"/central-registry/section.html?view=staff","permanent":false},
    {"source":"/access","destination":"/central-registry/section.html?view=access","permanent":false},
    {"source":"/sync","destination":"/central-registry/section.html?view=sync","permanent":false}
  ],
  "rewrites":[
    {"source":"/styles.css","destination":"/central-registry/simple.css"},
    {"source":"/config.js","destination":"/central-registry/config.js"},
    {"source":"/session.js","destination":"/central-registry/session.js"},
    {"source":"/app.js","destination":"/central-registry/app.js"},
    {"source":"/app-icon.svg","destination":"/central-registry/app-icon.svg"},
    {"source":"/manifest.webmanifest","destination":"/central-registry/manifest.webmanifest"}
  ],
  "headers":[{"source":"/(.*)","headers":[
    {"key":"X-Content-Type-Options","value":"nosniff"},
    {"key":"Referrer-Policy","value":"strict-origin-when-cross-origin"},
    {"key":"X-Frame-Options","value":"DENY"},
    {"key":"Cache-Control","value":"no-store, max-age=0"}
  ]}]
}
