{
  "$schema":"https://openapi.vercel.sh/vercel.json",
  "cleanUrls":true,
  "trailingSlash":false,
  "redirects":[
    {"source":"/","destination":"/attendance-dashboard/control-room.html","permanent":false},
    {"source":"/students","destination":"/attendance-dashboard/index.html","permanent":false},
    {"source":"/staff","destination":"/attendance-dashboard/staff.html","permanent":false},
    {"source":"/analytics","destination":"/attendance-dashboard/analytics.html","permanent":false},
    {"source":"/devices","destination":"/attendance-dashboard/device-security.html","permanent":false}
  ],
  "rewrites":[
    {"source":"/styles.css","destination":"/attendance-dashboard/simple.css"},
    {"source":"/app.js","destination":"/attendance-dashboard/app.js"},
    {"source":"/production-ui.css","destination":"/attendance-dashboard/production-ui.css"},
    {"source":"/session-hardening.js","destination":"/attendance-dashboard/session-hardening.js"},
    {"source":"/manifest.webmanifest","destination":"/attendance-dashboard/manifest.webmanifest"},
    {"source":"/app-icon.svg","destination":"/attendance-dashboard/app-icon.svg"}
  ],
  "headers":[{"source":"/(.*)","headers":[
    {"key":"X-Content-Type-Options","value":"nosniff"},
    {"key":"Referrer-Policy","value":"strict-origin-when-cross-origin"},
    {"key":"Permissions-Policy","value":"camera=(self), geolocation=(self), microphone=()"},
    {"key":"X-Frame-Options","value":"SAMEORIGIN"},
    {"key":"Cache-Control","value":"no-store, max-age=0"}
  ]}]
}
