{
  "$schema":"https://openapi.vercel.sh/vercel.json",
  "cleanUrls":true,
  "trailingSlash":false,
  "redirects":[
    {"source":"/","destination":"/notification-control/index.html","permanent":false},
    {"source":"/notifications","destination":"/notification-control/index.html","permanent":false},
    {"source":"/contacts","destination":"/notification-control/section.html?view=contacts","permanent":false},
    {"source":"/templates","destination":"/notification-control/section.html?view=templates","permanent":false},
    {"source":"/messages","destination":"/notification-control/section.html?view=messages","permanent":false},
    {"source":"/attempts","destination":"/notification-control/section.html?view=attempts","permanent":false},
    {"source":"/providers","destination":"/notification-control/section.html?view=providers","permanent":false},
    {"source":"/readiness","destination":"/notification-control/section.html?view=readiness","permanent":false},
    {"source":"/imports","destination":"/notification-control/imports.html","permanent":false},
    {"source":"/registry","destination":"/central-registry/index.html","permanent":false}
  ],
  "rewrites":[
    {"source":"/styles.css","destination":"/central-registry/simple.css"},
    {"source":"/config.js","destination":"/central-registry/config.js"},
    {"source":"/session.js","destination":"/central-registry/session.js"},
    {"source":"/app.js","destination":"/central-registry/app.js"},
    {"source":"/app-icon.svg","destination":"/central-registry/app-icon.svg"},
    {"source":"/manifest.webmanifest","destination":"/central-registry/manifest.webmanifest"}
  ],
  "headers":[{"source":"/(.*)","headers":[
    {"key":"X-Content-Type-Options","value":"nosniff"},
    {"key":"Referrer-Policy","value":"strict-origin-when-cross-origin"},
    {"key":"X-Frame-Options","value":"DENY"},
    {"key":"Cache-Control","value":"no-store, max-age=0"}
  ]}]
}
