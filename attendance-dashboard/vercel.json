{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/", "destination": "/control-room.html", "permanent": false },
    { "source": "/parents", "destination": "/parent-contacts.html", "permanent": false },
    { "source": "/students", "destination": "/index.html", "permanent": false },
    { "source": "/staff", "destination": "/staff.html", "permanent": false },
    { "source": "/operations", "destination": "/operations.html", "permanent": false },
    { "source": "/analytics", "destination": "/analytics.html", "permanent": false },
    { "source": "/controls", "destination": "/controls.html", "permanent": false },
    { "source": "/deployment", "destination": "/deployment-tools.html", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), geolocation=(self), microphone=()" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    },
    {
      "source": "/attendance-config.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
